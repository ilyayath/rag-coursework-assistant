# ── LLM ──────────────────────────────────────────────────────────────────────
# Тип LLM: "ollama" (локальний) або "openai" (хмарний)
LLM_TYPE=ollama

# Назва моделі Ollama (ollama pull mistral)
LLM_MODEL=mistral

# Адреса сервера Ollama
# Локальний запуск:      OLLAMA_BASE_URL=http://localhost:11434
# З Docker-контейнера:   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Таймаут запиту до Ollama у секундах (захист від зависання)
OLLAMA_TIMEOUT_SEC=120

# API-ключ OpenAI (потрібен лише якщо LLM_TYPE=openai)
# OPENAI_API_KEY=sk-...

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Розмір фрагмента (символів)
CHUNK_SIZE=500

# Перекриття між сусідніми фрагментами (символів)
CHUNK_OVERLAP=100

# Кількість кандидатів для векторного пошуку (до реранкінгу)
K_RETRIEVAL=12

# Поріг відстані для фільтрації нерелевантних фрагментів (L2, all-MiniLM)
SCORE_THRESHOLD=1.2

# Реранкер: увімкнути/вимкнути, модель, кількість топ фрагментів
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# Мінімальна довжина фрагмента після чанкінгу (символів)
MIN_CHUNK_LEN=30

# Максимальний розмір файлу для завантаження (МБ)
MAX_FILE_SIZE_MB=50

# Кількість пар повідомлень у контексті діалогу
CONVERSATION_HISTORY_TURNS=3
