# ── LLM ──────────────────────────────────────────────────────────────────────
# Тип LLM: "ollama" (локальний) або "openai" (хмарний)
LLM_TYPE=ollama

# Назва моделі Ollama (ollama pull mistral)
LLM_MODEL=mistral

# Адреса сервера Ollama
# Локальний запуск:      OLLAMA_BASE_URL=http://localhost:11434
# З Docker-контейнера:   OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Таймаут запиту до Ollama у секундах (захист від зависання)
OLLAMA_TIMEOUT_SEC=120

# API-ключ OpenAI (потрібен лише якщо LLM_TYPE=openai)
# OPENAI_API_KEY=sk-...

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Розмір фрагмента (символів)
CHUNK_SIZE=500

# Перекриття між сусідніми фрагментами (символів)
CHUNK_OVERLAP=100

# Кількість кандидатів для векторного пошуку (до реранкінгу)
K_RETRIEVAL=12
